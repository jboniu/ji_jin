.field-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  font-size: 28rpx;
  color: #5a5146;
}

.field-input {
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f6f2e8;
  font-size: 28rpx;
  color: #2d2a26;
}

.save-button,
.delete-button {
  margin-top: 8rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.save-button {
  background: #1f6b52;
  color: #fffdf8;
}

.delete-button {
  background: #f9e7e4;
  color: #9f3f32;
}
