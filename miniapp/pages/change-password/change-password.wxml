<view class="page-shell stack">
  <view class="hero-card stack">
    <view class="section-title">修改密码</view>
    <view class="muted-text">当前用户：{{userId}}</view>
    <view class="muted-text" wx:if="{{message}}">{{message}}</view>
  </view>

  <view class="section-card stack">
    <view class="field-block">
      <view class="field-label">旧密码</view>
      <input
        class="field-input"
        password
        value="{{form.oldPassword}}"
        placeholder="请输入旧密码"
        bindinput="handleOldPasswordInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">新密码</view>
      <input
        class="field-input"
        password
        value="{{form.newPassword}}"
        placeholder="请输入新密码"
        bindinput="handleNewPasswordInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">确认新密码</view>
      <input
        class="field-input"
        password
        value="{{form.confirmPassword}}"
        placeholder="请再次输入新密码"
        bindinput="handleConfirmPasswordInput"
      />
    </view>

    <button class="save-button" bindtap="handleSubmit" loading="{{saving}}">确认修改</button>
  </view>
</view>
