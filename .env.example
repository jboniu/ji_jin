LLM_PROVIDER=zhipu
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=glm-4.7-flash
OPENAI_FALLBACK_MODELS=glm-4-flash,glm-5.1
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
DATABASE_URL=postgresql://username:password@host:5432/database_name
DATA_BACKEND_STRICT=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET_UPLOADS=uploads
SUPABASE_STORAGE_BUCKET_REPORTS=reports
STORAGE_BACKEND_STRICT=false

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true
EMAIL_FROM=your_email@example.com
EMAIL_TO=receiver@example.com

TASK_TIME=14:20
TASK_WEEKDAYS=Monday,Tuesday,Wednesday,Thursday,Friday
